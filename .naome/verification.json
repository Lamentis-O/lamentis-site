{
  "schema": "naome.verification.v1",
  "version": 1,
  "status": "ready",
  "lastUpdated": "2026-05-23",
  "checks": [
    {
      "id": "diff-check",
      "command": "git diff --check",
      "cwd": ".",
      "purpose": "Reject whitespace errors in the current diff.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "naome-harness-health",
      "command": "node .naome/bin/check-harness-health.js",
      "cwd": ".",
      "purpose": "Validate the installed NAOME harness before feature work or task completion.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/bin/check-harness-health.js"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "naome-task-state",
      "command": "node .naome/bin/check-task-state.js",
      "cwd": ".",
      "purpose": "Validate the NAOME task-state contract for the current repository.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/bin/check-task-state.js",
        ".naome/task-contract.schema.json"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "repository-quality-check",
      "command": "node .naome/bin/naome.js quality check --changed",
      "cwd": ".",
      "purpose": "Validate changed files against deterministic NAOME repository quality rules.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/repository-quality.json",
        ".naome/repository-structure.json",
        ".naome/repository-quality-baseline.json"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "repository-semantic-check",
      "command": "node .naome/bin/naome.js semantic check --changed",
      "cwd": ".",
      "purpose": "Validate changed files against deterministic NAOME semantic cleanup rules.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/repository-quality.json",
        ".naome/repository-quality-baseline.json"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "repository-frontend-lint",
      "command": "cd frontend && npm run lint",
      "cwd": ".",
      "purpose": "Run Next.js frontend lint checks.",
      "cost": "medium",
      "source": "Repository package scripts",
      "evidence": [
        "frontend/package.json",
        "frontend/.eslintrc.*"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "repository-frontend-build",
      "command": "cd frontend && npm run build",
      "cwd": ".",
      "purpose": "Run Next.js production build for the frontend package.",
      "cost": "medium",
      "source": "Repository package scripts",
      "evidence": [
        "frontend/package.json",
        "frontend/next.config.ts",
        "frontend/app"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "repository-frontend-test-unit",
      "command": "cd frontend && npm run test",
      "cwd": ".",
      "purpose": "Run frontend unit tests (Vitest).",
      "cost": "fast",
      "source": "Repository package scripts",
      "evidence": [
        "frontend/package.json",
        "frontend/vitest.config.ts",
        "frontend/tests/setup.ts",
        "frontend/tests/page.test.tsx"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "ui-style-check",
      "command": "node .naome/bin/naome.js ui check --changed --json",
      "cwd": ".",
      "purpose": "Validate changed SwiftUI files against the NAOME UI contract.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        ".naome/ui-contract.json"
      ],
      "lastVerified": "2026-05-23"
    },
    {
      "id": "architecture-fitness-check",
      "command": "node .naome/bin/naome.js arch validate --changed-only",
      "cwd": ".",
      "purpose": "Validate changed files against deterministic NAOME architecture fitness rules.",
      "cost": "fast",
      "source": "NAOME built-in",
      "evidence": [
        "naome.arch.yaml",
        "docs/naome/architecture-fitness.md"
      ],
      "lastVerified": "2026-05-23"
    }
  ],
  "phases": [
    {
      "id": "shape-health",
      "order": 10,
      "checkIds": [
        "naome-harness-health",
        "naome-task-state"
      ]
    },
    {
      "id": "quality",
      "order": 20,
      "checkIds": [
        "repository-quality-check",
        "repository-semantic-check",
        "repository-frontend-lint",
        "repository-frontend-build",
        "repository-frontend-test-unit",
        "ui-style-check",
        "architecture-fitness-check"
      ]
    },
    {
      "id": "diff-check",
      "order": 60,
      "checkIds": [
        "diff-check"
      ]
    }
  ],
  "changeTypes": [
    {
      "id": "architecture-policy",
      "description": "Architecture fitness policy and configuration.",
      "paths": [
        "naome.arch.yaml"
      ],
      "requiredChecks": [
        "architecture-fitness-check",
        "repository-quality-check",
        "repository-semantic-check",
        "diff-check"
      ],
      "recommendedChecks": [],
      "humanReview": false
    },
    {
      "id": "frontend-source",
      "description": "Frontend source and deployment-relevant config.",
      "paths": [
        "frontend/app/**",
        "frontend/components/**",
        "frontend/public/**",
        "frontend/package.json",
        "frontend/next.config.ts",
        "frontend/eslint.config.mjs",
        "frontend/tsconfig.json",
        "frontend/postcss.config.mjs",
        "frontend/next-env.d.ts"
      ],
      "requiredChecks": [
        "repository-frontend-lint",
        "repository-frontend-build",
        "repository-frontend-test-unit",
        "repository-quality-check",
        "repository-semantic-check",
        "diff-check"
      ],
      "recommendedChecks": [
        "architecture-fitness-check"
      ],
      "humanReview": false
    }
  ],
  "releaseGates": [
    {
      "checkId": "architecture-fitness-check",
      "requiredWhen": "Before release or any source, manifest, alias, config, or structure change that can affect architecture."
    },
    {
      "checkId": "repository-frontend-lint",
      "requiredWhen": "Before release for any frontend source or config change."
    },
    {
      "checkId": "repository-frontend-build",
      "requiredWhen": "Before release for any frontend source or config change."
    },
    {
      "checkId": "repository-frontend-test-unit",
      "requiredWhen": "Before release for any frontend source or config change."
    }
  ]
}
