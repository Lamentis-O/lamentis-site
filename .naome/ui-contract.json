{
  "schema": "naome.ui-contract.v1",
  "version": 1,
  "optOut": {
    "platformProfiles": []
  },
  "platformProfiles": [
    {
      "id": "ios-swiftui",
      "fileGlobs": ["**/*.swift"],
      "tokens": {
        "textStyles": [
          { "id": "typography.largeTitle", "swiftui": "AppTextStyle.largeTitle" },
          { "id": "typography.title", "swiftui": "AppTextStyle.title" },
          { "id": "typography.headline", "swiftui": "AppTextStyle.headline" },
          { "id": "typography.body", "swiftui": "AppTextStyle.body" },
          { "id": "typography.caption", "swiftui": "AppTextStyle.caption" }
        ],
        "spacing": [
          { "id": "spacing.xs", "value": 4, "swiftui": "AppSpacing.xs" },
          { "id": "spacing.sm", "value": 8, "swiftui": "AppSpacing.sm" },
          { "id": "spacing.md", "value": 16, "swiftui": "AppSpacing.md" },
          { "id": "spacing.lg", "value": 24, "swiftui": "AppSpacing.lg" },
          { "id": "spacing.xl", "value": 32, "swiftui": "AppSpacing.xl" },
          { "id": "size.controlHeight", "value": 44, "swiftui": "AppSize.controlHeight" },
          { "id": "size.iconButton", "value": 34, "swiftui": "AppSize.iconButton" }
        ],
        "radius": [
          { "id": "radius.sm", "value": 6, "swiftui": "AppRadius.sm" },
          { "id": "radius.md", "value": 10, "swiftui": "AppRadius.md" },
          { "id": "radius.card", "value": 12, "swiftui": "AppRadius.card" }
        ],
        "colors": [
          { "id": "color.text.primary", "swiftui": "AppColor.textPrimary" },
          { "id": "color.text.secondary", "swiftui": "AppColor.textSecondary" },
          { "id": "color.surface.primary", "swiftui": "AppColor.surfacePrimary" },
          { "id": "color.surface.card", "swiftui": "AppColor.surfaceCard" },
          { "id": "color.accent.primary", "swiftui": "AppColor.accentPrimary" },
          { "id": "color.feedback.destructive", "swiftui": "AppColor.destructive" }
        ]
      },
      "components": [
        {
          "id": "component.primary-button",
          "name": "PrimaryButton",
          "swiftuiType": "PrimaryButton",
          "adHocPatterns": ["Button("],
          "severity": "warning"
        },
        {
          "id": "component.app-text-field",
          "name": "AppTextField",
          "swiftuiType": "AppTextField",
          "adHocPatterns": ["TextField("],
          "severity": "warning"
        },
        {
          "id": "component.app-card",
          "name": "AppCard",
          "swiftuiType": "AppCard",
          "adHocPatterns": [".background(", ".cornerRadius("],
          "severity": "warning"
        },
        {
          "id": "component.app-list-row",
          "name": "AppListRow",
          "swiftuiType": "AppListRow",
          "adHocPatterns": ["List {", "ForEach("],
          "severity": "warning"
        }
      ],
      "rules": [
        { "id": "ios-swiftui.no-hardcoded-system-font", "severity": "error" },
        {
          "id": "ios-swiftui.no-magic-spacing",
          "severity": "error",
          "allowedLiterals": [
            { "value": 0, "contexts": [".padding", ".safeAreaPadding", ".frame", ".offset", ".cornerRadius", ".contentMargins", ".safeAreaInset", "spacing", "CGFloat"] },
            { "value": 1, "contexts": ["geometry-sentinel", "separator"] }
          ]
        },
        { "id": "ios-swiftui.no-direct-color", "severity": "error" },
        { "id": "ios-swiftui.prefer-registered-component", "severity": "warning" }
      ]
    }
  ]
}
